
{
    "version": 2,
    "builds": [
      {
        "src": "Backend/wsgi.py",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "15mb" }
      }
    ],
    "routes": [
      {
        "src": "/static/(.*)",
        "dest": "/staticfiles/"
      },
      {
        "src": "/(.*)",
        "dest": "/wsgi.py"
      }
    ],
    "build": {
      "env": {
        "DJANGO_SETTINGS_MODULE": "Backend.settings",
        "PYTHONUNBUFFERED": "1"
      },
      "command": "python manage.py collectstatic --noinput && python manage.py migrate"
    }
    
  }
  